# Copy to .env and fill in. .env is gitignored.
#
# These samples talk DIRECTLY to Azure AI Foundry — no LiteLLM proxy in
# the middle. So callers need real Azure keys (the ones the proxy was
# hiding) and the actual Foundry endpoint hostnames.

# ---- Main Foundry resource (Sweden Central) -------------------------
# Hosts: gpt-4*, o-series, gpt-5*, embeddings, gpt-image-2, mistral OCR,
# Anthropic (Claude), Azure AI Inference (Grok/Kimi/Phi/DeepSeek),
# MAI-Image-2, FLUX.2-pro, gpt-realtime
AZURE_API_KEY=PUT-REAL-FOUNDRY-KEY-HERE
AZURE_COGNITIVE_ENDPOINT=https://iexigtsazurioneyeai.cognitiveservices.azure.com
AZURE_FOUNDRY_ENDPOINT=https://iexigtsazurioneyeai.services.ai.azure.com

# ---- TTS resource (East US 2) — gpt-4o-mini-tts ---------------------
AZURE_API_KEY_TTS=PUT-REAL-TTS-KEY-HERE
AZURE_OPENAI_TTS_ENDPOINT=https://iexigtsazurioneye-openai.openai.azure.com
AZURE_OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts-2

# ---- Realtime resource (Canada East) — translate / whisper ---------
AZURE_REALTIME_API_KEY=PUT-REAL-CANADA-KEY-HERE
AZURE_REALTIME_ENDPOINT=iexigtsazurioneyeai-can-resource.openai.azure.com

# ---- Azure Cognitive Services Speech (Sweden Central) ---------------
AZURE_SPEECH_KEY=PUT-REAL-AZURE-SPEECH-KEY-HERE
AZURE_SPEECH_REGION=swedencentral

# ---- Azure AI Search (for the RAG sample) ---------------------------
# Required only by rag/run.py. Leave blank to skip that sample.
AZURE_SEARCH_ENDPOINT=https://iexigtsazurioneyeai-search.search.windows.net
AZURE_SEARCH_INDEX=eval-rag
AZURE_SEARCH_API_KEY=PUT-AZURE-SEARCH-ADMIN-OR-QUERY-KEY-HERE

# ---- Networking -----------------------------------------------------
# Set to False on networks with TLS interception (e.g. corporate proxies).
# Disables certificate verification for Azure HTTPS / WSS calls.
SSL_VERIFY=True
